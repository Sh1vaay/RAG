# ==============================================================================
# RAG Project Environment Configuration Template
# Copy this file to `.env` and fill in your keys. Do not commit `.env` to git!
# ==============================================================================

# --- OpenAI Configuration ---
# Your OpenAI API key for embeddings and LLM generations (Required)
OPENAI_API_KEY=your_openai_api_key_here

# --- LangSmith Tracing & Observability (Optional) ---
# Set to true to enable LangChain tracing, monitoring, and debugging
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="rag-agent-playground"

# --- Query Routing Configuration ---
# Choose the routing engine: 
# - 'semantic': In-memory embeddings classification (Zero LLM tokens, <10ms latency)
# - 'llm': LLM-based structured reasoning (Uses gpt-4o-mini, provides reasoning text)
ROUTING_METHOD=semantic
